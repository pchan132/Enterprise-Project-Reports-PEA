# ============================================================================
# Database (Supabase PostgreSQL)
# ============================================================================

# Connect to Supabase via connection pooling
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection to the database. Used for migrations
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres"

# ============================================================================
# 🔐 Session & Authentication
# ============================================================================

# Secret key สำหรับ HMAC-sign session tokens (อย่างน้อย 32 chars)
# สร้างด้วยคำสั่ง: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=""

# User credentials (JSON array)
# passwordHash สร้างด้วย SHA-256: node -e "console.log(require('crypto').createHash('sha256').update('YOUR_PASSWORD').digest('hex'))"
# ตัวอย่าง:
# AUTH_USERS='[{"username":"admin","passwordHash":"03ac674216f3e15c761ee1a5e255f067953623c8b388b4459e13f978d7c846f4"}]'
AUTH_USERS=''

# ============================================================================
# Line Messaging API
# ============================================================================

LINE_CHANNEL_ID=""
LINE_CHANNEL_ACCESS_TOKEN=""
LINE_GROUP_ID=""
# Channel Secret สำหรับตรวจสอบ x-line-signature บน Webhook (ดูได้ที่ LINE Developers Console > Basic settings > Channel secret)
LINE_CHANNEL_SECRET="95f8258512f3030b9262dda8dcd7218a"
